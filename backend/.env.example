# Copy this file to `backend/.env` and fill in real values.
# `.env` is gitignored; never commit real secrets.

# OpenAI API key used by api/views.py (_OpenAIHelper).
OPENAI_API_KEY=sk-your-key-here

# Django secret key. Generate one, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me

# Debug mode. Use False in production.
DJANGO_DEBUG=True

# Comma-separated allowed hosts.
DJANGO_ALLOWED_HOSTS=argumind.uitae.kim,localhost,127.0.0.1,0.0.0.0

# Optional DRF throttle rate overrides (default shown).
# DRF_THROTTLE_GET_TOPIC=30/min
# DRF_THROTTLE_GET_ARGUMENT=30/min
# DRF_THROTTLE_GET_SCORES=60/min
